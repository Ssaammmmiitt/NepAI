# NepAI Frontend — environment variables
# Copy to .env for local development:
#   cp .env.example .env
#
# Vite only exposes variables prefixed with VITE_ to the browser bundle.

# API base URL used by Axios (src/services/api.ts)
# Local dev:  /api  — Vite dev server proxies this to the backend
# Production: full URL to your deployed FastAPI server
#   e.g. https://api.yourdomain.com/api
#   or /api if frontend and API share the same origin (reverse proxy)
VITE_API_URL=/api

# Dev-only: backend URL for Vite's /api proxy (not sent to the browser)
# Change if your FastAPI server runs on a different host/port locally.
DEV_API_PROXY=http://localhost:8000
